# Copy to terraform.tfvars and fill in values.
# Sensitive values can also be set via environment variables:
#   export TF_VAR_vault_token="..."
#   export TF_VAR_harbor_admin_password="..."
#   export TF_VAR_state_encryption_passphrase="..."

vault_addr  = "https://vault.support.example.com"
vault_token = ""

harbor_url            = "https://harbor.support.example.com"
harbor_admin_user     = "admin"
harbor_admin_password = ""

state_encryption_passphrase = ""

# Kubernetes auth config — set these after cluster is running.
# The import-cluster.sh script extracts these automatically.
# k8s_host               = "https://10.69.50.20:6443"
# k8s_token_reviewer_jwt = ""
# k8s_ca_cert            = ""
