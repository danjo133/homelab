# -*- mode: ruby -*-
# vi: set ft=ruby :

require 'yaml'

# Support VM stays hardcoded (shared infrastructure)
SUPPORT_MAC = "52:54:00:69:50:10"

# Load all cluster configs from iac/clusters/*/cluster.yaml
clusters = Dir.glob(File.join(File.dirname(__FILE__), 'clusters', '*', 'cluster.yaml')).map { |f|
  YAML.load_file(f)
}.sort_by { |c| c['name'] }

Vagrant.configure("2") do |config|
  # Base configuration for all boxes
  # Using local NixOS qcow image with libvirt
  config.vm.box = "local/nixos-25.11-vagrant"
  config.vm.box_url = "file://#{File.expand_path(File.dirname(__FILE__))}/nixos-25.11-vagrant.box"

  # SSH configuration - use custom ECDSA key instead of insecure key
  config.ssh.private_key_path = File.expand_path("~/.vagrant.d/ecdsa_private_key")
  config.ssh.insert_key = false
  # Prevent terminal escape sequences from corrupting Vagrant commands
  config.ssh.shell = "TERM=dumb bash -l"
  # Disable Vagrant's hostname setting - NixOS box doesn't have /etc/nixos structure
  # Hostname is set via NixOS configuration
  config.vm.hostname = nil

  # Shared folder configuration - disabled for NixOS
  config.vm.synced_folder ".", "/vagrant", disabled: true
  # Prevent Vagrant from modifying /etc/fstab (read-only on NixOS)
  config.vm.allow_fstab_modification = false

  # Default provider: libvirt with KVM (for Arch Linux)
  config.vm.provider "libvirt" do |libvirt|
    libvirt.driver = "kvm"
    libvirt.graphics_type = "spice"
    libvirt.graphics_port = -1
    libvirt.graphics_autoport = true
    libvirt.qemu_use_session = false
    # Disable QEMU guest agent (we use DHCP for IP, not agent queries)
    libvirt.qemu_use_agent = false
  end

  # Set libvirt as the default provider
  ENV['VAGRANT_DEFAULT_PROVIDER'] = 'libvirt'

  # Supporting Systems VM
  # Hosts: Vault, Harbor, MinIO, NFS, Keycloak, Teleport, GitLab
  config.vm.define "support" do |support|
    support.vm.network :public_network,
      dev: "br-k8s",
      mode: "bridge",
      type: "bridge",
      mac: SUPPORT_MAC,
      auto_config: false

    support.vm.provider "libvirt" do |libvirt|
      libvirt.memory = 24576
      libvirt.cpus = 4
      libvirt.machine_virtual_size = 150
      libvirt.disk_bus = "virtio"
      libvirt.disk_driver :cache => "directsync"
      libvirt.cpu_mode = "host-passthrough"
    end
  end

  # Cluster VMs - generated from cluster.yaml configs
  clusters.each do |cluster|
    name = cluster['name']

    # Master node
    config.vm.define "#{name}-master" do |master|
      master.vm.network :public_network,
        dev: "br-k8s",
        mode: "bridge",
        type: "bridge",
        mac: cluster['master']['mac'],
        auto_config: false

      master.vm.provider "libvirt" do |libvirt|
        libvirt.memory = cluster['master']['memory']
        libvirt.cpus = cluster['master']['cpus']
        libvirt.machine_virtual_size = cluster['master'].fetch('disk', 20)
        libvirt.disk_bus = "virtio"
        libvirt.disk_driver :cache => "directsync"
        libvirt.cpu_mode = "host-passthrough"
      end
    end

    # Worker nodes
    cluster['workers'].each do |worker|
      config.vm.define "#{name}-#{worker['name']}" do |w|
        w.vm.network :public_network,
          dev: "br-k8s",
          mode: "bridge",
          type: "bridge",
          mac: worker['mac'],
          auto_config: false

        w.vm.provider "libvirt" do |libvirt|
          libvirt.memory = worker['memory']
          libvirt.cpus = worker['cpus']
          libvirt.machine_virtual_size = worker.fetch('disk', 20)
          libvirt.disk_bus = "virtio"
          libvirt.disk_driver :cache => "directsync"
          libvirt.cpu_mode = "host-passthrough"
        end
      end
    end
  end
end
