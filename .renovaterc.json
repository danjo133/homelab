{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":enableVulnerabilityAlerts",
    "docker:pinDigests"
  ],
  "platform": "gitlab",
  "timezone": "UTC",
  "schedule": ["after 10pm every day"],
  "minimumReleaseAge": "14 days",
  "labels": ["dependencies", "renovate"],
  "commitMessagePrefix": "chore(deps): ",
  "commitMessageTopic": "{{depName}}",
  "semanticCommits": "enabled",
  "semanticCommitScope": "deps",
  "prConcurrentLimit": 5,
  "prCreationLimit": 3,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["vulnerability", "security"],
    "minimumReleaseAge": "0 days",
    "schedule": ["at any time"]
  },
  "enabledManagers": [
    "custom.regex",
    "dockerfile",
    "docker-compose",
    "gitlabci",
    "helm-values",
    "helmfile",
    "kubernetes",
    "nix",
    "npm",
    "poetry",
    "pip_requirements"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Helm chart versions in ArgoCD Application templates",
      "fileMatch": ["iac/argocd/chart/templates/wave.*\\.yaml$"],
      "matchStrings": [
        "repoURL:\\s+(?<registryUrl>https?://[^\\s{]+)\\s+chart:\\s+(?<depName>[^\\s{]+)\\s+targetRevision:\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "helm",
      "versioningTemplate": "helm"
    },
{
      "customType": "regex",
      "description": "Container images in ArgoCD values files",
      "fileMatch": ["iac/argocd/values/.*\\.yaml$"],
      "matchStrings": [
        "# renovate: datasource=docker depName=(?<depName>[^\\s]+)\\s+(?:image|tag):\\s+\"?(?<currentValue>[^\"\\s]+)\"?"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Group all Istio charts together",
      "matchDatasources": ["helm"],
      "matchPackagePatterns": ["^istio", "^ztunnel"],
      "groupName": "Istio",
      "labels": ["istio", "network"]
    },
    {
      "description": "Group Cilium and Tetragon together",
      "matchDatasources": ["helm"],
      "matchPackagePatterns": ["^cilium$", "^tetragon$"],
      "groupName": "Cilium",
      "labels": ["cilium", "network"]
    },
    {
      "description": "Group Grafana stack charts together",
      "matchDatasources": ["helm"],
      "matchPackageNames": ["loki", "tempo", "alloy", "beyla"],
      "groupName": "Grafana stack",
      "labels": ["monitoring"]
    },
    {
      "description": "Group SPIRE charts together",
      "matchDatasources": ["helm"],
      "matchPackagePatterns": ["^spire"],
      "groupName": "SPIRE",
      "labels": ["identity"]
    },
    {
      "description": "Security-critical vulnerability fixes — immediate, no age gate",
      "matchUpdateTypes": ["patch"],
      "isVulnerabilityAlert": true,
      "minimumReleaseAge": "0 days",
      "schedule": ["at any time"],
      "automerge": true,
      "labels": ["security-patch"]
    },
    {
      "description": "Patch updates — auto-merge after pipeline passes",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true,
      "labels": ["patch"]
    },
    {
      "description": "Minor version updates — auto-merge after pipeline passes",
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "labels": ["minor-update"]
    },
    {
      "description": "Major version updates — require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update", "breaking-change"],
      "minimumReleaseAge": "30 days"
    },
    {
      "description": "kube-prometheus-stack — separate MR, careful review",
      "matchDatasources": ["helm"],
      "matchPackageNames": ["kube-prometheus-stack"],
      "groupName": "kube-prometheus-stack",
      "automerge": false,
      "labels": ["monitoring", "breaking-change"]
    },
    {
      "description": "Kubernetes and RKE2 — monthly, manual review",
      "matchDatasources": ["github-releases"],
      "matchPackagePatterns": ["kubernetes", "rke2"],
      "schedule": ["after 10pm on the second Monday of the month"],
      "automerge": false,
      "labels": ["kubernetes"],
      "minimumReleaseAge": "30 days"
    },
    {
      "description": "Ignore custom app images — ArgoCD Image Updater handles these",
      "matchDatasources": ["docker"],
      "matchPackagePatterns": [
        "harbor\\.example\\.com/apps/",
        "/apps/portal$",
        "/apps/jit-elevation$",
        "/apps/cluster-setup$",
        "/apps/architecture$",
        "/apps/openclaw$"
      ],
      "enabled": false
    }
  ],
  "hostRules": [
    {
      "description": "Docker Hub rate limiting",
      "matchHost": "docker.io",
      "concurrentRequestLimit": 2
    },
    {
      "description": "Harbor registry auth (set RENOVATE_HARBOR_TOKEN in CI vars)",
      "matchHost": "harbor.example.com",
      "hostType": "docker",
      "username": "${HARBOR_PUSH_USER}",
      "password": "${HARBOR_PUSH_PASSWORD}"
    }
  ],
  "suppressNotifications": ["prIgnoreNotification"]
}
